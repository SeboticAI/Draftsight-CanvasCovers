<Window x:Class="CanvasCovers.UI.Products.LiftBlanket.LiftBlanketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CanvasCovers.UI.Controls"
        Title="Adelaide Annexes &amp; Canvas — Lift Blanket Generator"
        Width="840"
        Height="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="800"
        MinHeight="620"
        ShowInTaskbar="True">
    <Window.InputBindings>
        <!-- Esc closes the dialog. Can't use IsCancel="True" on the button
             because that sets DialogResult, which throws on non-modal
             windows (the dialog is opened via Show(), not ShowDialog()). -->
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="CloseCommand_Executed" />
    </Window.CommandBindings>
    <Window.Resources>
        <SolidColorBrush x:Key="BrandAccent" Color="#C77B30" />
        <SolidColorBrush x:Key="SectionHeader" Color="#1A3A52" />
        <SolidColorBrush x:Key="SectionDivider" Color="#DDDDDD" />
        <SolidColorBrush x:Key="MutedText" Color="#666666" />

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SectionHeader}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>
        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedText}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Margin" Value="0,2,0,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4,16,4" />
        </Style>
        <Style x:Key="SectionPanel" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource SectionDivider}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,4,0,16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <controls:BrandedHeader x:Name="Header" DockPanel.Dock="Top" />

        <Border DockPanel.Dock="Bottom" Background="#F4F4F4" BorderBrush="{StaticResource SectionDivider}" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <TextBlock Name="ErrorText"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="#B33"
                           FontWeight="SemiBold"
                           Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="CancelButton"
                            Width="100" Height="30"
                            Margin="0,0,8,0"
                            Content="Cancel"
                            Click="CancelButton_Click" />
                    <Button Name="GenerateButton"
                            Width="160" Height="30"
                            IsDefault="True"
                            Background="{StaticResource BrandAccent}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Content="Generate Drawing"
                            Click="GenerateButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>

                <Border Style="{StaticResource SectionPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="PROJECT INFORMATION" />
                        <controls:ProjectMetadataPanel x:Name="MetadataPanel" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="WALLS" />
                        <TextBlock Style="{StaticResource MutedLabel}"
                                   Text="One tab per wall. Type the measurements where they sit on the sheet; the blanket redraws live. Rear tab is disabled when Through Car is ticked." />
                        <TabControl x:Name="WallTabs" MinHeight="460" BorderThickness="1">
                            <TabItem Header="Left Wall">
                                <controls:WallBlanket x:Name="LeftBlanket" Margin="8" />
                            </TabItem>
                            <TabItem Header="Right Wall">
                                <controls:WallBlanket x:Name="RightBlanket" Margin="8" />
                            </TabItem>
                            <TabItem x:Name="RearTab" Header="Rear Wall">
                                <controls:WallBlanket x:Name="RearBlanket" Margin="8" />
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="OPTIONS" />
                        <WrapPanel>
                            <CheckBox Name="ThroughCarOption"
                                      Content="Through Car (omits rear wall)"
                                      Checked="ThroughCarOption_Changed"
                                      Unchecked="ThroughCarOption_Changed" />
                            <CheckBox Name="PlasticCoverOption" Content="Plastic Cover on COP" />
                        </WrapPanel>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Fixings Required" />
                            <ComboBox Grid.Column="1" Name="FixingsInput" SelectedIndex="3" SelectionChanged="FixingsInput_SelectionChanged">
                                <ComboBoxItem Content="Velcro (0)" Tag="Velcro" />
                                <ComboBoxItem Content="Self-adhesive Velcro (0)" Tag="SelfAdhesiveVelcro" />
                                <ComboBoxItem Content="Hooks Facing In (-50)" Tag="HooksFacingIn" />
                                <ComboBoxItem Content="Hooks Facing Out (-50)" Tag="HooksFacingOut" />
                                <ComboBoxItem Content="Press Studs (-40)" Tag="PressStuds" />
                                <ComboBoxItem Content="Eyelet (-30)" Tag="Eyelet" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Fixing Allowance (mm)" />
                            <TextBox Grid.Column="1" Name="FixingAllowanceInput" Text="50" TextChanged="SharedParam_Changed" />
                            <TextBlock Grid.Column="2" Style="{StaticResource MutedLabel}"
                                       Text="Subtracted from each wall's measured height before the height is doubled." />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Quilt Inset (mm)" />
                            <TextBox Grid.Column="1" Name="QuiltInsetInput" Text="5" TextChanged="SharedParam_Changed" />
                            <TextBlock Grid.Column="2" Style="{StaticResource MutedLabel}"
                                       Text="Distance the quilting lines are pulled in from the outline so the pen clears the cut edge. The outline is always the entered size." />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Quilting Spacing (mm)" />
                            <TextBox Grid.Column="1" Name="QuiltingSpacingInput" Text="700" TextChanged="SharedParam_Changed" />
                            <TextBlock Grid.Column="2" Style="{StaticResource MutedLabel}"
                                       Text="Target gap between horizontal quilt lines; lines even-divide so spacing lands cleanly." />
                        </Grid>
                        <CheckBox Name="QuiltingOption" Margin="0,8,0,0" IsChecked="True"
                                  Checked="SharedParam_Changed" Unchecked="SharedParam_Changed"
                                  Content="Draw quilting lines" />
                        <CheckBox Name="ExportDxfOption" Margin="0,8,0,0" IsChecked="True"
                                  Content="Open DXF export dialog after generating" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}" BorderThickness="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="LAYERS" />
                        <controls:LayersPanel x:Name="LayersControl" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
