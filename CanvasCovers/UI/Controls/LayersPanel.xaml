<UserControl x:Class="CanvasCovers.UI.Controls.LayersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
        <Style x:Key="SwatchBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#333333" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Width" Value="24" />
        </Style>
    </UserControl.Resources>
    <StackPanel>
        <DockPanel Margin="0,2,0,8">
            <Button DockPanel.Dock="Right"
                    Name="ResetButton"
                    Padding="10,3"
                    Margin="8,0,0,0"
                    Content="Reset to Defaults"
                    Click="ResetButton_Click" />
            <TextBlock TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Foreground="#666666" FontSize="11" FontStyle="Italic"
                       Text="Defaults are tuned for the standard cutting setup. Override only if your CAM software expects different layer names or colors. ACI (AutoCAD Color Index): 1=Red, 2=Yellow, 3=Green, 4=Cyan, 5=Blue, 6=Magenta, 7=Black." />
        </DockPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Purpose" FontWeight="SemiBold" />
            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldLabel}" Text="Layer Name" FontWeight="SemiBold" />
            <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="ACI" FontWeight="SemiBold" />

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Wall outlines (cuts)" />
            <TextBox Grid.Row="1" Grid.Column="1" Name="OutlineName" Text="1 Rotary Blade" />
            <TextBox Grid.Row="1" Grid.Column="3" Name="OutlineAci" Text="5" />
            <Border Grid.Row="1" Grid.Column="5" Name="OutlineSwatch" Style="{StaticResource SwatchBorder}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="COP cutouts" />
            <TextBox Grid.Row="2" Grid.Column="1" Name="CopName" Text="1 Rotary Blade" />
            <TextBox Grid.Row="2" Grid.Column="3" Name="CopAci" Text="5" />
            <Border Grid.Row="2" Grid.Column="5" Name="CopSwatch" Style="{StaticResource SwatchBorder}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Annotations (no cut)" />
            <TextBox Grid.Row="3" Grid.Column="1" Name="AnnotationName" Text="5 Draw and Text" />
            <TextBox Grid.Row="3" Grid.Column="3" Name="AnnotationAci" Text="6" />
            <Border Grid.Row="3" Grid.Column="5" Name="AnnotationSwatch" Style="{StaticResource SwatchBorder}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Project info + dims" />
            <TextBox Grid.Row="4" Grid.Column="1" Name="TitleblockName" Text="0" />
            <TextBox Grid.Row="4" Grid.Column="3" Name="TitleblockAci" Text="7" />
            <Border Grid.Row="4" Grid.Column="5" Name="TitleblockSwatch" Style="{StaticResource SwatchBorder}" />
        </Grid>
    </StackPanel>
</UserControl>
