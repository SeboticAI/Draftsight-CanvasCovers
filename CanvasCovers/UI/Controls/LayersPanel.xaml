<UserControl x:Class="CanvasCovers.UI.Controls.LayersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <DockPanel Margin="0,2,0,8">
            <Button DockPanel.Dock="Right"
                    Name="ResetButton"
                    Padding="10,3"
                    Margin="8,0,0,0"
                    Content="Reset to Defaults"
                    Click="ResetButton_Click" />
            <TextBlock TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Foreground="#666666" FontSize="11" FontStyle="Italic"
                       Text="The cutter's full layer set. Pick each layer's colour, and assign which role (cut outline, COP, annotation, title block) draws on it. All layers are created in the DXF; only assigned ones carry geometry." />
        </DockPanel>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Layer" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,8,0" />
            <TextBlock Grid.Column="1" Text="Colour" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,8,0" />
            <TextBlock Grid.Column="2" Text="Cut" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="COP" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="Annot." FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="5" Text="Title" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" />
        </Grid>

        <!-- The seven layer rows are built in code-behind into this panel. -->
        <StackPanel Name="RowsPanel" />
    </StackPanel>
</UserControl>
