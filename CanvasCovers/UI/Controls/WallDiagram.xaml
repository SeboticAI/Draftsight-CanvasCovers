<UserControl x:Class="CanvasCovers.UI.Controls.WallDiagram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280">
    <Border BorderBrush="#DDDDDD"
            BorderThickness="1"
            Background="#FBFBFC"
            CornerRadius="3"
            Padding="6">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Foreground="#1A3A52"
                       FontWeight="SemiBold"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,4"
                       Text="LEFT WALL" />
            <Canvas x:Name="DrawCanvas"
                    Width="260"
                    Height="290"
                    Background="Transparent"
                    SnapsToDevicePixels="True" />
            <TextBlock x:Name="HintText"
                       Foreground="#888888"
                       FontStyle="Italic"
                       FontSize="10"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="4,4,4,2"
                       Text="Click any field to highlight what it controls." />
        </StackPanel>
    </Border>
</UserControl>
